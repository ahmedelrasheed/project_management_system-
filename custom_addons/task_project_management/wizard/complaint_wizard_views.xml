<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_complaint_wizard_form" model="ir.ui.view">
        <field name="name">task.management.complaint.wizard.form</field>
        <field name="model">task.management.complaint.wizard</field>
        <field name="arch" type="xml">
            <form string="File Complaint">
                <group>
                    <field name="task_id" readonly="1"/>
                    <field name="message" placeholder="Describe your complaint..."
                           widget="text"/>
                </group>
                <footer>
                    <button name="action_submit" string="Submit Complaint"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
