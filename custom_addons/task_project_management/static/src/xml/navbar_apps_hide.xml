<templates xml:space="preserve">

    <!-- Remove the Apps Menu (hamburger/grid icon) from the main navbar -->
    <t t-name="task_project_management.NavBar" t-inherit="web.NavBar" t-inherit-mode="extension">
        <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace">
            <!-- Apps menu removed -->
        </xpath>
    </t>

</templates>
