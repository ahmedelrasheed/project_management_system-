title **Odoo Task & Project Management System**\n**Complete Workflow Sequence Diagram**

actor "Member\n(Fatima)" as Member #LightBlue
actor "Project Manager\n(Ahmed)" as PM #LightGreen
actor "Admin Manager\n(Omar)" as Admin #Gold
participant "Odoo\nBackend" as Odoo #F3EDF2
database "Database\n(PostgreSQL)" as DB #LightGray
participant "Mail\nThread" as Mail #LightCoral
participant "Cron\nScheduler" as Cron #LightYellow
participant "Export\nWizard" as Export #PaleGreen

== **1. SYSTEM CONFIGURATION (Admin)** ==

Admin -> Odoo : Open Settings > Task Management
activate Odoo
Odoo -> DB : Load res.config.settings
DB --> Odoo : Current settings
Odoo --> Admin : Show settings form
Admin -> Odoo : Configure:\n- Past date limit: 3 days\n- After-midnight tasks: Disabled\n- Max attachment size: 100MB
Odoo -> DB : Save ir.config_parameter:\n  past_date_limit=3\n  allow_after_midnight=False\n  max_attachment_size=100
DB --> Odoo : Settings saved
Odoo --> Admin : Configuration saved
deactivate Odoo

== **2. MEMBER MANAGEMENT (Admin)** ==

Admin -> Odoo : Navigate to Members > New
activate Odoo
Admin -> Odoo : Fill member data:\nName, Email, Phone, Job Title, Address, Role
Odoo -> Odoo : member.create(vals)
note right of Odoo
  Auto-creates res.users
  with login=email,
  password="123456",
  assigns role group
end note
Odoo -> DB : Create task.management.member
Odoo -> DB : Create res.users (linked)
Odoo -> DB : Assign security group\n(group_member / group_project_manager / group_admin_manager)
DB --> Odoo : Member + User created
Odoo --> Admin : Member "Fatima" created
deactivate Odoo

== **3. PROJECT CREATION (Admin)** ==

Admin -> Odoo : Navigate to Projects > New
activate Odoo
Admin -> Odoo : Fill project data:\nName: "Website Redesign"\nExpected Hours: 200\nExpected End Date: 2026-06-01\nPMs: [Ahmed, Nora]\nMembers: [Fatima, Khalid, Sara]\nStatus: Active
Odoo -> Odoo : project.create(vals)
Odoo -> Odoo : _check_pm_not_member()
note right of Odoo
  Validate: PM cannot
  also be a member of
  the same project
end note
Odoo -> Odoo : _check_at_least_one_pm()
Odoo -> DB : Create task.management.project\nwith M2M relations
DB --> Odoo : Project created (ID=1)
Odoo --> Admin : Project "Website Redesign" created
deactivate Odoo

== **4. MEMBER CREATES A TASK** ==

Member -> Odoo : Login via Odoo authentication
activate Odoo
Odoo -> DB : Authenticate user (res.users)
DB --> Odoo : Session established
Odoo --> Member : Redirect to task dashboard

Member -> Odoo : Click "New Task"
Odoo -> DB : Fetch active projects\nwhere member is assigned
DB --> Odoo : ["Website Redesign"]
Odoo --> Member : Show task form\n(project dropdown filtered)

Member -> Odoo : Submit task:\nDate: 2026-02-19\nDescription: "Homepage Design"\nProject: Website Redesign\nTime From: 09:00 | Time To: 12:00\nAttachment: homepage_v1.pdf (15MB)
Odoo -> Odoo : task.create(vals)
activate Odoo #F3EDF2

group Validation Checks
    Odoo -> Odoo : _check_time_validity()\ntime_to > time_from? (after-midnight disabled)
    Odoo -> Odoo : _check_time_overlap()\nNo overlapping tasks for this member on this date
    Odoo -> Odoo : _check_past_date_limit()\nDate within 3-day limit for members
    Odoo -> Odoo : _check_member_in_project()\nFatima is assigned to "Website Redesign"
    Odoo -> Odoo : _check_project_status()\nProject status == "active"
end

Odoo -> Odoo : Auto-set member_id\nfrom current user\n(_get_member_for_user)
Odoo -> Odoo : Set entry_timestamp = now()
Odoo -> Odoo : _compute_duration_hours()\n12.0 - 9.0 = 3.0 hours
Odoo -> Odoo : _compute_is_late_entry()\nentry_date == task_date -> False
Odoo -> DB : INSERT task.management.task\n(status='pending')
DB --> Odoo : Task created (ID=1)

Odoo -> Odoo : _validate_attachment_size()\n15MB < 100MB limit -> OK
Odoo -> DB : Store ir.attachment (homepage_v1.pdf)
DB --> Odoo : Attachment stored

Odoo -> Odoo : _create_audit_entry(\nold=False, new='pending',\ncomment='Task created')
Odoo -> DB : INSERT task.management.task.audit\n(task_id=1, new_status='pending',\nchanged_by=Fatima, changed_at=now)
DB --> Odoo : Audit entry #1 created

deactivate Odoo

Odoo -> Mail : _notify_pm_on_submit()
activate Mail
Mail -> Mail : message_post(\nbody="New task by Fatima\nfor Website Redesign",\npartner_ids=[Ahmed, Nora])
Mail -> DB : Create mail.message\n(notification type)
Mail -> DB : Create mail.notification\n(bell icon for PMs)
Mail --> PM : Bell notification:\n"New task submitted by Fatima"
Mail --> PM : Email notification
deactivate Mail

Odoo --> Member : Task saved (status: Pending)
deactivate Odoo

== **5. OVERLAPPING TIME BLOCKED** ==

Member -> Odoo : Submit another task:\nDate: 2026-02-19\nTime From: 11:00 | Time To: 14:00
activate Odoo
Odoo -> Odoo : _check_time_overlap()
Odoo -> DB : Search tasks for Fatima on 2026-02-19
DB --> Odoo : Found: Task #1 (09:00-12:00)
Odoo -> Odoo : _times_overlap(11.0, 14.0, 9.0, 12.0)\n11:00 < 12:00 AND 09:00 < 14:00 -> OVERLAP!
Odoo --> Member : **ValidationError:**\n"Time overlap! You have a task\nfrom 09:00 to 12:00 on 2026-02-19"
deactivate Odoo

== **6. PM REVIEWS AND APPROVES A TASK** ==

PM -> Odoo : Login and open "Website Redesign"\n> Tasks to Review
activate Odoo
Odoo -> DB : Search tasks where\nproject PMs include Ahmed\nAND status='pending'
DB --> Odoo : [Task #1: Fatima - "Homepage Design"]
Odoo --> PM : Show pending tasks list

PM -> Odoo : Open Task #1\nAdd comment: "Excellent, add mobile version"\nClick "Approve"
Odoo -> Odoo : action_approve()
Odoo -> Odoo : _check_can_approve()
note right of Odoo
  1. Is admin? No
  2. Is Ahmed the task owner? No (Fatima's task)
  3. Is Ahmed a PM of this project? Yes
  -> Approved
end note

Odoo -> Odoo : write({approval_status: 'approved',\nmanager_comment: '...'})
note right of Odoo
  Capture old_statuses
  BEFORE super().write()
  old_status = 'pending'
end note
Odoo -> DB : UPDATE task SET\napproval_status='approved',\nmanager_comment='Excellent...'
DB --> Odoo : Task updated

Odoo -> Odoo : _create_audit_entry(\nold='pending', new='approved')
Odoo -> DB : INSERT task.management.task.audit\n(old='pending', new='approved',\nchanged_by=Ahmed)
DB --> Odoo : Audit entry #2 created

Odoo -> Mail : _notify_member_status_change('approved')
activate Mail
Mail -> Mail : message_post(\nbody='Your task "Homepage Design"\nhas been Approved.\nComment: Excellent...',\npartner_ids=[Fatima])
Mail --> Member : Bell: "Task Approved"
Mail --> Member : Email: "Task Approved"
deactivate Mail

Odoo -> DB : _compute_total_logged_hours()\nProject: sum approved tasks = 3.0 hrs
Odoo -> DB : _compute_progress_percentage()\n3.0/200 * 100 = 1.5%
Odoo --> PM : Task approved successfully
deactivate Odoo

== **7. PM REJECTS A TASK** ==

PM -> Odoo : Open Khalid's task\nComment: "Need more details"\nClick "Reject"
activate Odoo
Odoo -> Odoo : action_reject()
Odoo -> Odoo : _check_can_approve() -> OK
Odoo -> Odoo : write({approval_status: 'rejected',\nmanager_comment: 'Need more details'})
Odoo -> DB : UPDATE task SET\napproval_status='rejected'
DB --> Odoo : Task updated

Odoo -> Odoo : _create_audit_entry(\nold='pending', new='rejected')
Odoo -> DB : INSERT task.management.task.audit
DB --> Odoo : Audit entry created

Odoo -> Mail : _notify_member_status_change('rejected')
activate Mail
Mail --> Member : Bell + Email:\n"Task rejected: Need more details"
deactivate Mail

Odoo --> PM : Task rejected
deactivate Odoo

== **8. MEMBER EDITS REJECTED TASK (Resubmission)** ==

Member -> Odoo : Open rejected task\nEdit description with more details\nClick Save
activate Odoo
Odoo -> Odoo : write(vals) on rejected task
note right of Odoo
  task.approval_status == 'rejected'
  AND editing non-status fields
  -> Auto-reset to 'pending'
  vals['approval_status'] = 'pending'
end note
Odoo -> DB : UPDATE task SET\ndescription='...',\napproval_status='pending'
DB --> Odoo : Task updated

Odoo -> Odoo : _create_audit_entry(\nold='rejected', new='pending')
Odoo -> DB : INSERT task.management.task.audit\n(old='rejected', new='pending')
DB --> Odoo : Audit entry created
note right of DB
  Full audit trail:
  #1: null -> pending (Created)
  #2: pending -> rejected (PM)
  #3: rejected -> pending (Resubmit)
end note

Odoo -> Mail : _notify_pm_on_submit()\n(resubmission notification)
activate Mail
Mail --> PM : Bell + Email:\n"Fatima resubmitted task"
deactivate Mail

Odoo --> Member : Task saved (status reset to Pending)
deactivate Odoo

== **9. CANNOT EDIT APPROVED TASK** ==

Member -> Odoo : Try to edit an approved task
activate Odoo
Odoo -> Odoo : write(vals)\ntask.approval_status == 'approved'\nediting non-allowed fields
Odoo --> Member : **UserError:**\n"Cannot edit an approved task"
deactivate Odoo

== **10. CANNOT DELETE ANY TASK** ==

Member -> Odoo : Try to delete a task
activate Odoo
Odoo -> Odoo : unlink()
Odoo --> Member : **UserError:**\n"Tasks cannot be deleted.\nYou can only edit them."
deactivate Odoo

== **11. ADMIN APPROVES TASK ON ANY PROJECT** ==

Admin -> Odoo : Open any project task\nClick "Approve"
activate Odoo
Odoo -> Odoo : _check_can_approve()
note right of Odoo
  is_admin = True
  -> Skip all checks
  Admin can approve
  any task on any project
end note
Odoo -> DB : UPDATE task SET approval_status='approved'
Odoo -> DB : INSERT audit entry
Odoo -> Mail : Notify member
Odoo --> Admin : Task approved
deactivate Odoo

== **12. PM CANNOT APPROVE OWN TASKS** ==

PM -> Odoo : (As member of "Mobile App")\nTry to approve own task
activate Odoo
Odoo -> Odoo : _check_can_approve()
Odoo -> Odoo : member == task.member_id -> True
Odoo --> PM : **UserError:**\n"You cannot approve or reject\nyour own tasks"
deactivate Odoo

== **13. PROJECT STATUS CHANGES** ==

Admin -> Odoo : Change "Website Redesign"\nstatus to "On Hold"
activate Odoo
Odoo -> DB : UPDATE project SET status='on_hold'
Odoo --> Admin : Project set to On Hold
deactivate Odoo

Member -> Odoo : Try to submit task\nfor "Website Redesign"
activate Odoo
Odoo -> Odoo : _check_project_status()
